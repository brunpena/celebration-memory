# Copie este arquivo para `.env.local` e preencha com os valores do seu
# projeto Supabase (Project Settings > API).
#
# IMPORTANTE: essas mesmas variáveis também precisam ser configuradas no
# painel da Vercel em Project Settings > Environment Variables, senão o
# deploy de produção retorna "Internal Server Error" em todas as rotas.

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# URL pública do site, usada para montar links de redirecionamento de e-mail
# (recuperação de senha, confirmação de cadastro etc). Em produção, use a URL
# do domínio da Vercel.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
